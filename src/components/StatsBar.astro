---
import GlowCard from './GlowCard.astro';

interface Props {
  storyCount: number;
  sourceCount: number;
  categoryCount: number;
}

const { storyCount, sourceCount, categoryCount } = Astro.props;

const stats = [
  { value: storyCount, label: 'Stories Today', accent: 'var(--color-accent)' },
  { value: sourceCount, label: 'Sources', accent: '#a855f7' },
  { value: categoryCount, label: 'Categories', accent: '#06b6d4' },
];
---
<div class="grid grid-cols-3 gap-4 mb-10">
  {stats.map(({ value, label, accent }) => (
    <GlowCard>
      <div class="p-5">
        <p class="text-3xl font-extrabold text-[var(--color-text)] mb-1">{value}</p>
        <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">{label}</p>
      </div>
    </GlowCard>
  ))}
</div>
