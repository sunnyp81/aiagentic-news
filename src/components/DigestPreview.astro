---
import type { Digest } from '../lib/types';
import GlowCard from './GlowCard.astro';

interface Props {
  digest: Digest;
}

const { digest } = Astro.props;
const date = new Date(digest.publishedAt).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const preview = digest.content.split(/[.\n]/).filter(Boolean).slice(0, 2).join('. ').slice(0, 180) + '...';
---
<a href={`/digest/${digest.date}/`} class="block mb-10 group">
  <GlowCard>
    <div class="relative overflow-hidden p-8">
      <div class="absolute top-0 right-0 w-48 h-48 bg-[var(--color-accent)]/[0.03] rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2"></div>
      <div class="relative">
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md bg-[var(--color-accent)]/10 text-xs font-semibold text-[var(--color-accent)] uppercase tracking-wider">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
            Daily Digest
          </span>
          <time class="text-xs text-[var(--color-text-muted)]">{date}</time>
        </div>
        <h2 class="text-xl sm:text-2xl font-bold text-[var(--color-text)] mb-3 group-hover:text-[var(--color-accent-hover)] transition-colors">{digest.title}</h2>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">{preview}</p>
        <span class="inline-flex items-center gap-1 mt-4 text-sm text-[var(--color-accent)] font-medium group-hover:gap-2 transition-all">
          Read digest <span class="text-lg">→</span>
        </span>
      </div>
    </div>
  </GlowCard>
</a>
