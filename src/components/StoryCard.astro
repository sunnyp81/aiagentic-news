---
import type { Story } from '../lib/types';
import { getCategoryById, toTitleCase } from '../lib/categories';
import GlowCard from './GlowCard.astro';

interface Props {
  story: Story;
}

const { story } = Astro.props;
const cat = getCategoryById(story.category);

const timeAgo = (() => {
  const diff = Date.now() - new Date(story.publishedAt).getTime();
  const hours = Math.floor(diff / 3600000);
  if (hours < 1) return 'Just now';
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
})();

const excerpt = story.summary.split('. ').slice(0, 2).join('. ') + '.';
---
<a href={`/story/${story.slug}/`} class="group block">
  <GlowCard>
    <article class="p-6 h-full">
      <div class="flex items-center gap-3 mb-4">
        <span
          class="cat-badge px-2.5 py-1 rounded-md text-[11px] font-semibold uppercase tracking-wider text-white/90"
          style={`background-color: ${cat.color};`}
        >
          {cat.label}
        </span>
        <span class="text-xs text-[var(--color-text-muted)]">{timeAgo}</span>
        {story.sources.length > 1 && (
          <span class="text-xs text-[var(--color-text-muted)] ml-auto flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
            {story.sources.length}
          </span>
        )}
      </div>
      <h3 class="text-[17px] font-semibold leading-snug mb-3 text-[var(--color-text)] group-hover:text-[var(--color-accent-hover)] transition-colors">
        {toTitleCase(story.title)}
      </h3>
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-3 mb-4">{excerpt}</p>
      <div class="flex items-center gap-2 pt-3 border-t border-[var(--color-border-subtle)]">
        {story.sources.slice(0, 3).map((src, i) => (
          <span class="text-xs text-[var(--color-text-muted)]">
            {src.name}{i < Math.min(story.sources.length, 3) - 1 ? ' · ' : ''}
          </span>
        ))}
        <span class="ml-auto text-xs text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity">Read →</span>
      </div>
    </article>
  </GlowCard>
</a>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
