---
import type { Story } from '../lib/types';
import { getCategoryById } from '../lib/categories';

interface Props {
  story: Story;
}

const { story } = Astro.props;
const cat = getCategoryById(story.category);

const timeAgo = (() => {
  const diff = Date.now() - new Date(story.publishedAt).getTime();
  const hours = Math.floor(diff / 3600000);
  if (hours < 1) return 'Just now';
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
})();

const excerpt = story.summary.split('. ').slice(0, 2).join('. ') + '.';
---
<a href={`/story/${story.slug}/`} class="group block">
  <article class="relative bg-[var(--color-bg-card)] border border-[var(--color-border-subtle)] rounded-xl p-6 hover:border-[var(--color-accent)]/30 hover:shadow-[0_0_30px_var(--color-accent-glow)] transition-all duration-300">
    <div class="flex items-center gap-3 mb-4">
      <span
        class="px-2.5 py-1 rounded-md text-[11px] font-semibold uppercase tracking-wider text-white/90"
        style={`background-color: ${cat.color}`}
      >
        {cat.label}
      </span>
      <span class="text-xs text-[var(--color-text-muted)]">{timeAgo}</span>
      {story.sources.length > 1 && (
        <span class="text-xs text-[var(--color-text-muted)] ml-auto">{story.sources.length} sources</span>
      )}
    </div>
    <h3 class="text-[17px] font-semibold leading-snug mb-3 text-[var(--color-text)] group-hover:text-[var(--color-accent-hover)] transition-colors">
      {story.title}
    </h3>
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-3">{excerpt}</p>
    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-[var(--color-border-subtle)]">
      {story.sources.slice(0, 3).map((src, i) => (
        <span class="text-xs text-[var(--color-text-muted)]">
          {src.name}{i < Math.min(story.sources.length, 3) - 1 ? ' · ' : ''}
        </span>
      ))}
    </div>
  </article>
</a>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
