---
import type { Story } from '../lib/types';
import { getCategoryById, toTitleCase } from '../lib/categories';
import GlowCard from './GlowCard.astro';

interface Props {
  story: Story;
}

const { story } = Astro.props;
const cat = getCategoryById(story.category);
const WORKER = 'https://aiagentic-news-worker.sunnypat81.workers.dev';
const ogImage = `${WORKER}/og?title=${encodeURIComponent(story.title)}&category=${story.category}`;

const timeAgo = (() => {
  const diff = Date.now() - new Date(story.publishedAt).getTime();
  const hours = Math.floor(diff / 3600000);
  if (hours < 1) return 'Just now';
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
})();

const excerpt = story.summary.split('. ').slice(0, 2).join('. ') + '.';
---
<a href={`/story/${story.slug}/`} class="group block h-full">
  <GlowCard>
    <article class="flex flex-col h-full">
      <!-- Thumbnail image -->
      <div class="relative overflow-hidden" style="aspect-ratio: 600/315">
        <img
          src={ogImage}
          alt=""
          width="600"
          height="315"
          class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-500"
          loading="lazy"
        />
        <!-- Category badge overlaid on image -->
        <span
          class="absolute top-3 left-3 px-2.5 py-1 rounded-md text-[11px] font-bold uppercase tracking-wider text-white shadow-lg"
          style={`background-color: ${cat.color};`}
        >
          {cat.label}
        </span>
        <span class="absolute top-3 right-3 text-[11px] text-white/70 bg-black/40 backdrop-blur-sm px-2 py-1 rounded-md">{timeAgo}</span>
      </div>

      <!-- Text content -->
      <div class="flex flex-col flex-1 p-5">
        <h3 class="text-[16px] font-semibold leading-snug mb-2.5 text-[var(--color-text)] group-hover:text-[var(--color-accent-hover)] transition-colors line-clamp-2">
          {toTitleCase(story.title)}
        </h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-2 mb-4 flex-1">{excerpt}</p>
        <div class="flex items-center gap-1.5 pt-3 border-t border-[var(--color-border-subtle)]">
          {story.sources.slice(0, 2).map((src, i) => (
            <span class="text-xs text-[var(--color-text-muted)]">
              {src.name}{i < Math.min(story.sources.length, 2) - 1 ? ' ·' : ''}
            </span>
          ))}
          {story.sources.length > 2 && (
            <span class="text-xs text-[var(--color-text-muted)]">+{story.sources.length - 2}</span>
          )}
          <span class="ml-auto text-xs font-medium text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity">Read →</span>
        </div>
      </div>
    </article>
  </GlowCard>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
