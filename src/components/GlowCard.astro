---
interface Props {
  class?: string;
  tag?: string;
  href?: string;
}
const { class: className = '', tag = 'div', href } = Astro.props;
const Tag = tag as any;
---
<Tag class:list={['glow-wrap group', className]} href={href}>
  <div class="glow-content">
    <slot />
  </div>
</Tag>

<style>
  .glow-wrap {
    position: relative;
    display: block;
    border-radius: 0.75rem;
    padding: 1px;
    overflow: hidden;
    background: var(--color-border-subtle);
  }
  .glow-wrap::before {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(60deg);
    background: conic-gradient(
      transparent, #402fb5 5%, transparent 38%,
      transparent 50%, #cf30aa 60%, transparent 87%
    );
    opacity: 0;
    transition: opacity 0.4s ease, transform 2s ease;
    z-index: 0;
  }
  .glow-wrap:hover::before {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(-120deg);
  }

  .glow-content {
    position: relative;
    border-radius: 0.6875rem;
    background: var(--color-bg-card);
    height: 100%;
    z-index: 1;
  }
</style>
