---
interface Props {
  class?: string;
  tag?: string;
  href?: string;
}
const { class: className = '', tag = 'div', href } = Astro.props;
const Tag = tag as any;
---
<Tag class:list={['glow-wrap group', className]} href={href}>
  <!-- Outer glow layer -->
  <div class="glow-border glow-border-outer" aria-hidden="true"></div>
  <!-- Inner sharp border -->
  <div class="glow-border glow-border-inner" aria-hidden="true"></div>
  <!-- Content -->
  <div class="glow-content">
    <slot />
  </div>
</Tag>

<style>
  .glow-wrap {
    position: relative;
    display: block;
    border-radius: 0.75rem;
    isolation: isolate;
  }

  .glow-border {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }

  /* Outer soft glow */
  .glow-border-outer {
    inset: -1px;
    filter: blur(3px);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .glow-wrap:hover .glow-border-outer {
    opacity: 1;
  }
  .glow-border-outer::before {
    content: '';
    position: absolute;
    width: 800px;
    height: 800px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(60deg);
    background: conic-gradient(
      #000, #402fb5 5%, #000 38%,
      #000 50%, #cf30aa 60%, #000 87%
    );
    transition: transform 2s ease;
  }
  .glow-wrap:hover .glow-border-outer::before {
    transform: translate(-50%, -50%) rotate(-120deg);
  }

  /* Inner crisp border */
  .glow-border-inner {
    inset: 0;
    filter: blur(0.5px);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .glow-wrap:hover .glow-border-inner {
    opacity: 1;
  }
  .glow-border-inner::before {
    content: '';
    position: absolute;
    width: 800px;
    height: 800px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(70deg);
    background: conic-gradient(
      #0a0e17, #402fb5 5%, #0a0e17 14%,
      #0a0e17 50%, #cf30aa 60%, #0a0e17 64%
    );
    transition: transform 2s ease;
  }
  .glow-wrap:hover .glow-border-inner::before {
    transform: translate(-50%, -50%) rotate(-110deg);
  }

  .glow-content {
    position: relative;
    border-radius: inherit;
    background: var(--color-bg-card);
    height: 100%;
    z-index: 1;
    /* Subtle default border when not hovered */
    border: 1px solid var(--color-border-subtle);
    transition: border-color 0.4s ease;
  }
  .glow-wrap:hover .glow-content {
    border-color: transparent;
  }
</style>
