---
interface Props {
  class?: string;
  tag?: string;
  href?: string;
}
const { class: className = '', tag = 'div', href } = Astro.props;
const Tag = tag as any;
---
<Tag class:list={['glow-wrap group', className]} href={href}>
  <div class="glow-content">
    <slot />
  </div>
</Tag>

<style>
  .glow-wrap {
    position: relative;
    display: block;
    border-radius: 0.75rem;
    padding: 1px;
    background: var(--color-border-subtle);
    transition: background 0.4s ease;
  }
  .glow-wrap::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: conic-gradient(
      transparent, #402fb5 5%, transparent 20%,
      transparent 50%, #cf30aa 55%, transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s ease, transform 2s ease;
    transform: rotate(60deg);
    z-index: 0;
    border-radius: 0.875rem;
    filter: blur(3px);
  }
  .glow-wrap::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: conic-gradient(
      transparent, #6366f1 5%, transparent 14%,
      transparent 50%, #a855f7 55%, transparent 64%
    );
    opacity: 0;
    transition: opacity 0.4s ease, transform 2s ease;
    transform: rotate(70deg);
    z-index: 0;
    border-radius: 0.875rem;
  }
  .glow-wrap:hover::before {
    opacity: 1;
    transform: rotate(-120deg);
  }
  .glow-wrap:hover::after {
    opacity: 1;
    transform: rotate(-110deg);
  }

  .glow-content {
    position: relative;
    border-radius: 0.6875rem;
    background: var(--color-bg-card);
    height: 100%;
    z-index: 1;
  }
</style>
