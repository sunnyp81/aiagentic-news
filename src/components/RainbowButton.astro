---
interface Props {
  href?: string;
  class?: string;
  target?: string;
}
const { href, class: className = '', target } = Astro.props;
const Tag = href ? 'a' : 'button';
---
<Tag href={href} target={target} class:list={['rb', className]} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>
  <slot />
</Tag>

<style>
  .rb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--color-accent);
    border-radius: 0.625rem;
    border: none;
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .rb:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
    color: white;
  }
</style>
