---
interface Props {
  href?: string;
  class?: string;
  target?: string;
}
const { href, class: className = '', target } = Astro.props;
const Tag = href ? 'a' : 'button';
---
<Tag href={href} target={target} class:list={['rb', className]} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>
  <span class="rb-inner"><slot /></span>
</Tag>

<style>
  .rb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    border-radius: 0.75rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    background: linear-gradient(
      45deg,
      #fb0094, #0000ff, #00ff00, #ffff00, #ff0000,
      #fb0094, #0000ff, #00ff00, #ffff00, #ff0000
    );
    background-size: 400%;
    animation: rainbow-shift 12s linear infinite;
    transition: transform 0.15s, filter 0.3s;
  }
  .rb:hover {
    transform: translateY(-1px);
    filter: brightness(1.15) drop-shadow(0 0 8px rgba(251,0,148,0.5));
  }
  .rb-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: #111827;
    border-radius: 0.5625rem;
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    white-space: nowrap;
  }
  @keyframes rainbow-shift {
    0%   { background-position: 0 0; }
    50%  { background-position: 400% 0; }
    100% { background-position: 0 0; }
  }
</style>
