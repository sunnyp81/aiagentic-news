---
// Floating particle dots animation
---
<div class="particles" aria-hidden="true">
  {Array.from({ length: 30 }).map((_, i) => (
    <div
      class="particle"
      style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --duration: ${15 + Math.random() * 25}s; --delay: ${-Math.random() * 20}s; --size: ${1 + Math.random() * 2}px; --opacity: ${0.1 + Math.random() * 0.3};`}
    />
  ))}
</div>

<style>
  .particles {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: var(--color-accent);
    opacity: var(--opacity);
    animation: particle-drift var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
  }
  @keyframes particle-drift {
    0%, 100% { transform: translate(0, 0); opacity: var(--opacity); }
    25% { transform: translate(40px, -30px); opacity: calc(var(--opacity) * 0.5); }
    50% { transform: translate(-20px, -60px); opacity: var(--opacity); }
    75% { transform: translate(30px, -20px); opacity: calc(var(--opacity) * 0.7); }
  }
</style>
