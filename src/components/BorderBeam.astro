---
interface Props {
  size?: number;
  duration?: number;
  colorFrom?: string;
  colorTo?: string;
  delay?: number;
}

const {
  size = 40,
  duration = 12,
  colorFrom = '#6366f1',
  colorTo = '#a855f7',
  delay = 0,
} = Astro.props;
---
<div
  class="border-beam"
  style={`--bb-size: ${size}; --bb-duration: ${duration}; --bb-color-from: ${colorFrom}; --bb-color-to: ${colorTo}; --bb-delay: -${delay}s;`}
  aria-hidden="true"
></div>

<style>
  .border-beam {
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid transparent;
    mask-clip: padding-box, border-box;
    mask-composite: intersect;
    -webkit-mask-clip: padding-box, border-box;
    -webkit-mask-composite: source-in;
    mask: linear-gradient(transparent, transparent), linear-gradient(white, white);
    -webkit-mask: linear-gradient(transparent, transparent), linear-gradient(white, white);
  }
  .border-beam::after {
    content: '';
    position: absolute;
    width: calc(var(--bb-size) * 1px);
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bb-color-from), var(--bb-color-to), transparent);
    opacity: 0.6;
    offset-anchor: 50% 50%;
    offset-path: rect(0 auto auto 0 round 12px);
    animation: border-beam-move calc(var(--bb-duration) * 1s) infinite linear;
    animation-delay: var(--bb-delay);
  }
  @keyframes border-beam-move {
    0% { offset-distance: 0%; }
    100% { offset-distance: 100%; }
  }
</style>
