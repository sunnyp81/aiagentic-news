---
const sources = [
  'TechCrunch', 'The Verge', 'Ars Technica', 'Wired', 'The Decoder',
  'VentureBeat', 'MIT Tech Review', 'OpenAI', 'DeepMind', 'arXiv',
  'Hacker News', 'Reddit',
];
---
<div class="py-6 border-t border-b border-[var(--color-border-subtle)] mb-10">
  <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest mb-3">Aggregating from</p>
  <div class="flex flex-wrap gap-2">
    {sources.map((name) => (
      <span class="source-badge group">
        <span class="source-glow" aria-hidden="true"></span>
        <span class="source-inner">{name}</span>
      </span>
    ))}
  </div>
</div>

<style>
  .source-badge {
    position: relative;
    display: inline-block;
    border-radius: 0.375rem;
    padding: 1px;
    overflow: hidden;
    background: var(--color-border-subtle);
    cursor: default;
  }
  .source-badge::before {
    content: '';
    position: absolute;
    width: 200px;
    height: 200px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(60deg);
    background: conic-gradient(transparent, #402fb5 5%, transparent 38%, transparent 50%, #cf30aa 60%, transparent 87%);
    opacity: 0;
    transition: opacity 0.3s, transform 1.5s ease;
    z-index: 0;
  }
  .source-badge:hover::before {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(-120deg);
  }
  .source-glow { display: none; }
  .source-inner {
    position: relative;
    display: block;
    padding: 0.25rem 0.625rem;
    border-radius: 0.3125rem;
    background: var(--color-bg);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    z-index: 1;
    transition: color 0.3s;
  }
  .source-badge:hover .source-inner {
    color: var(--color-text-secondary);
  }
</style>
