---
import LivePulse from './LivePulse.astro';
import { categories } from '../lib/categories';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
];
---
<header class="sticky top-0 z-50 backdrop-blur-xl bg-[var(--color-bg)]/80 border-b border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-[var(--color-accent)] to-purple-500 flex items-center justify-center text-white font-extrabold text-sm shadow-lg shadow-[var(--color-accent)]/20">AI</div>
      <div class="flex flex-col">
        <span class="text-[15px] font-bold leading-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
          Agentic<span class="text-[var(--color-text-muted)] font-normal">.news</span>
        </span>
        <span class="text-[10px] text-[var(--color-text-muted)] leading-tight">AI News, Auto-Curated</span>
      </div>
    </a>
    <div class="flex items-center gap-2 sm:gap-4">
      <LivePulse label="Updated every 4h" />
      <div class="hidden sm:block h-4 w-px bg-[var(--color-border)]"></div>
      <nav class="flex items-center gap-0.5 sm:gap-1">
        {navLinks.map(({ href, label }) => (
          <a href={href} class="px-2.5 sm:px-3 py-1.5 rounded-lg text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-hover)] transition-all">{label}</a>
        ))}
        <div class="hidden md:flex items-center gap-0.5">
          <span class="w-px h-4 bg-[var(--color-border)] mx-1"></span>
          {categories.slice(0, 4).map((cat) => (
            <a href={`/category/${cat.id}/`} class="px-2 py-1.5 rounded-lg text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-hover)] transition-all">{cat.label.split(' ')[0]}</a>
          ))}
        </div>
      </nav>
    </div>
  </div>
</header>
