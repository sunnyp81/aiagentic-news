---
import Base from '../../layouts/Base.astro';
import GlowCard from '../../components/GlowCard.astro';
import RainbowButton from '../../components/RainbowButton.astro';
import { getStoryBySlug, getAllStorySlugs, getStories } from '../../lib/kv';
import { getCategoryById, toTitleCase } from '../../lib/categories';

export async function getStaticPaths() {
  const slugs = await getAllStorySlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const story = await getStoryBySlug(slug!);

if (!story) {
  return Astro.redirect('/404');
}

const cat = getCategoryById(story.category);
const WORKER = 'https://aiagentic-news-worker.sunnypat81.workers.dev';
const ogImage = `${WORKER}/og?title=${encodeURIComponent(story.title)}&category=${story.category}`;
const date = new Date(story.publishedAt).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const time = new Date(story.publishedAt).toLocaleTimeString('en-GB', {
  hour: '2-digit',
  minute: '2-digit',
});

// Use content for the article body (richer), summary for meta
const bodyText = story.content || story.summary;
const wordCount = bodyText.split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 200));

// Split on double newlines for natural paragraphs
const paragraphs = bodyText.split(/\n\n+/).map(p => p.trim()).filter(Boolean);

// First 2 sentences of summary for meta description
const sentences = story.summary.split(/(?<=\.)\s+/);

// Related stories (same category, excluding current)
const allStories = await getStories();
const related = allStories
  .filter((s) => s.category === story.category && s.slug !== story.slug)
  .slice(0, 3);
---
<Base title={toTitleCase(story.title)} description={sentences.slice(0, 2).join(' ')} ogType="article" ogImage={ogImage}>
  <article class="max-w-3xl mx-auto">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-8 text-sm">
      <a href="/" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">Home</a>
      <span class="text-[var(--color-text-muted)]">/</span>
      <a href={`/category/${story.category}/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">{cat.label}</a>
      <span class="text-[var(--color-text-muted)]">/</span>
      <span class="text-[var(--color-text-secondary)] truncate max-w-[200px]">{toTitleCase(story.title)}</span>
    </div>

    <!-- Meta bar -->
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span
        class="px-3 py-1 rounded-md text-[11px] font-semibold uppercase tracking-wider text-white/90"
        style={`background-color: ${cat.color}`}
      >
        {cat.label}
      </span>
      <span class="flex items-center gap-1.5 text-sm text-[var(--color-text-muted)]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        {date}
      </span>
      <span class="text-[var(--color-border)]">|</span>
      <span class="flex items-center gap-1.5 text-sm text-[var(--color-text-muted)]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {readTime} min read
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-3xl sm:text-[2.5rem] font-extrabold leading-[1.15] mb-10 tracking-tight">{toTitleCase(story.title)}</h1>

    <!-- Article body -->
    <div class="space-y-6 mb-12">
      {paragraphs.map((para, i) => (
        <p class:list={[
          'leading-[1.85]',
          i === 0 ? 'text-[1.125rem] text-[var(--color-text)]' : 'text-base text-[var(--color-text-secondary)]',
        ]}>
          {i === 0 ? <Fragment><span class="text-[var(--color-accent)] font-semibold text-2xl leading-none mr-0.5">{para.charAt(0)}</span>{para.slice(1)}</Fragment> : para}
        </p>
      ))}
    </div>

    <!-- Key Takeaways -->
    {story.keyTakeaways && story.keyTakeaways.length > 0 && (
      <div class="mb-10 p-5 rounded-xl border border-[var(--color-accent)]/20 bg-[var(--color-accent)]/5">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3 flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Key Takeaways
        </h2>
        <ul class="space-y-2">
          {story.keyTakeaways.map((point) => (
            <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)]">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">→</span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Sources & Tags -->
    <GlowCard>
      <div class="p-6">
      <div class="flex flex-col sm:flex-row gap-6">
        <div class="flex-1">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-3 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            Original Sources
          </h2>
          <div class="flex flex-wrap gap-2">
            {story.sources.map((src) => (
              <a
                href={src.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg bg-[var(--color-bg)]/80 border border-[var(--color-border-subtle)] text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] transition-all"
              >
                <span class="text-xs">↗</span>
                {src.name}
              </a>
            ))}
          </div>
        </div>

        {story.tags.length > 0 && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-3 flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
              Tags
            </h2>
            <div class="flex flex-wrap gap-2">
              {story.tags.map((tag) => (
                <span class="px-2.5 py-1 rounded-md bg-[var(--color-bg)]/80 text-xs text-[var(--color-text-muted)] border border-[var(--color-border-subtle)]">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>
      </div>
    </GlowCard>

    <!-- CTA -->
    <div class="flex items-center justify-center gap-3 my-10 py-8 border-t border-b border-[var(--color-border-subtle)]">
      <RainbowButton href="/">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        Browse All Stories
      </RainbowButton>
      <RainbowButton href={`/category/${story.category}/`}>
        More {cat.label}
      </RainbowButton>
    </div>

    <!-- Related Stories -->
    {related.length > 0 && (
      <div class="mb-10">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-4 flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
          More in {cat.label}
        </h2>
        <div class="grid gap-3">
          {related.map((r) => (
            <a href={`/story/${r.slug}/`} class="group flex items-start gap-4 p-4 rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)]/30 hover:shadow-[0_0_30px_var(--color-accent-glow)] transition-all duration-300">
              <div class="flex-1">
                <p class="text-sm font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent-hover)] transition-colors leading-snug mb-1">{r.title}</p>
                <p class="text-xs text-[var(--color-text-muted)] line-clamp-2">{r.summary.split('. ').slice(0, 1).join('. ')}.</p>
              </div>
              <span class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent)] text-lg mt-1 transition-colors">→</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium transition-colors">
      <span>←</span> All stories
    </a>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": story.title,
    "description": sentences.slice(0, 2).join(' '),
    "datePublished": story.publishedAt,
    "author": { "@type": "Organization", "name": "AI Agentic News" },
    "publisher": { "@type": "Organization", "name": "AI Agentic News", "url": "https://aiagentic.news" },
  })} />
</Base>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
