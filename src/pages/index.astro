---
import Base from '../layouts/Base.astro';
import DigestPreview from '../components/DigestPreview.astro';
import CategoryChips from '../components/CategoryChips.astro';
import StoryCard from '../components/StoryCard.astro';
import StatsBar from '../components/StatsBar.astro';
import TrendingTags from '../components/TrendingTags.astro';
import SourceBadges from '../components/SourceBadges.astro';
import GlowCard from '../components/GlowCard.astro';
import RainbowButton from '../components/RainbowButton.astro';
import Marquee from '../components/Marquee.astro';
import { getStories, getDigests } from '../lib/kv';
import { categories, toTitleCase } from '../lib/categories';

const WORKER = 'https://aiagentic-news-worker.sunnypat81.workers.dev';
const stories = await getStories();
const digests = await getDigests();
const latestDigest = digests[0];

const featured = stories[0];
const rest = stories.slice(1);

const lastUpdated = stories.length > 0
  ? new Date(stories[0].publishedAt).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })
  : null;

const tickerItems = stories.slice(0, 8).map(s => s.title);
---
<Base title="Latest AI News">
  <!-- Hero Section -->
  <div class="relative mb-14">
    <div class="relative py-6">
      <div class="flex items-center gap-3 mb-5">
        {lastUpdated && (
          <span class="inline-flex items-center gap-2 text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-card)]/80 backdrop-blur border border-[var(--color-border-subtle)] px-3 py-1.5 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            Last updated {lastUpdated} UTC
          </span>
        )}
        <span class="text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-card)]/80 backdrop-blur border border-[var(--color-border-subtle)] px-3 py-1.5 rounded-full">
          {stories.length} stories today
        </span>
      </div>

      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tighter mb-4">
        <span class="bg-gradient-to-r from-[var(--color-accent)] via-purple-400 to-cyan-400 bg-clip-text text-transparent gradient-text-animate">AI News</span>
        <br />
        <span class="text-[var(--color-text)]">Curated by AI</span>
      </h1>
      <p class="text-[var(--color-text-muted)] text-base sm:text-lg max-w-lg leading-relaxed mb-6">Scraped from 13+ sources. Deduplicated. Synthesized. Delivered every 4 hours — fully automated.</p>
      <div class="flex flex-wrap items-center gap-3">
        <RainbowButton href="#stories">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
          Read Today's Stories
        </RainbowButton>
        <a href="/about/" class="px-4 py-2.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">How it works →</a>
      </div>
    </div>
  </div>

  <!-- News Ticker -->
  {tickerItems.length > 0 && <Marquee items={tickerItems} speed={50} />}

  <!-- Stats -->
  <StatsBar storyCount={stories.length} sourceCount={13} categoryCount={categories.length} />

  <!-- Digest -->
  {latestDigest && <DigestPreview digest={latestDigest} />}

  <!-- Trending Tags -->
  <TrendingTags stories={stories} />

  <!-- Categories -->
  <div class="mb-2">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-4 flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
      Filter by Category
    </h2>
  </div>
  <CategoryChips />

  <!-- Featured Story -->
  {featured && (
    <a href={`/story/${featured.slug}/`} class="block mb-10 group">
      <GlowCard>
        <div class="sm:flex">
          <!-- Image half -->
          <div class="sm:w-2/5 relative overflow-hidden" style="aspect-ratio: 16/9">
            <img
              src={`${WORKER}/og?title=${encodeURIComponent(featured.title)}&category=${featured.category}`}
              alt=""
              width="600"
              height="337"
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              loading="eager"
            />
          </div>
          <!-- Text half -->
          <div class="flex-1 p-6 sm:p-8 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-widest bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  Featured
                </span>
                <span class="inline-block px-2.5 py-1 rounded-md text-[10px] font-semibold uppercase tracking-wider text-white/90" style={`background-color: var(--color-cat-${featured.category});`}>
                  {featured.category}
                </span>
              </div>
              <h2 class="text-xl sm:text-2xl lg:text-3xl font-extrabold leading-[1.2] mb-3 text-[var(--color-text)] group-hover:text-[var(--color-accent-hover)] transition-colors tracking-tight">
                {toTitleCase(featured.title)}
              </h2>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-3">
                {featured.summary}
              </p>
            </div>
            <div class="flex items-center justify-between mt-5 pt-4 border-t border-[var(--color-border-subtle)]">
              <div class="flex items-center gap-1.5 flex-wrap">
                {featured.sources.slice(0, 3).map((src) => (
                  <span class="px-2 py-0.5 rounded bg-[var(--color-bg)]/60 border border-[var(--color-border-subtle)] text-[11px] text-[var(--color-text-muted)]">{src.name}</span>
                ))}
              </div>
              <span class="text-sm text-[var(--color-accent)] font-semibold group-hover:translate-x-1 transition-transform inline-block">→</span>
            </div>
          </div>
        </div>
      </GlowCard>
    </a>
  )}

  <!-- Section header -->
  <div class="flex items-center gap-4 mb-6">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
      <span id="stories">Latest Stories</span>
    </h2>
    <div class="flex-1 h-px bg-gradient-to-r from-[var(--color-border)] to-transparent"></div>
  </div>

  <!-- Story Grid with staggered animation -->
  <div class="grid gap-5 sm:grid-cols-2">
    {rest.map((story, i) => (
      <div class="fade-in-up" style={`animation-delay: ${i * 0.08}s`}>
        <StoryCard story={story} />
      </div>
    ))}
  </div>

  {stories.length === 0 && (
    <div class="text-center py-24">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-[var(--color-bg-card)] border border-[var(--color-border-subtle)] mb-6">
        <svg class="w-10 h-10 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
      </div>
      <p class="text-xl font-semibold text-[var(--color-text)] mb-2">No stories yet</p>
      <p class="text-sm text-[var(--color-text-muted)]">Stories are curated every 4 hours — check back soon</p>
    </div>
  )}

  <!-- Email Capture -->
  <div class="my-14 relative overflow-hidden rounded-2xl border border-[var(--color-accent)]/20 bg-gradient-to-br from-[var(--color-bg-card)] to-[var(--color-bg)]">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)]/5 to-transparent pointer-events-none"></div>
    <div class="relative p-8 sm:p-10 flex flex-col sm:flex-row items-start sm:items-center gap-8">
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></div>
          <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">Daily Digest</span>
        </div>
        <h2 class="text-2xl font-extrabold text-[var(--color-text)] mb-2 tracking-tight">Get the AI briefing in your inbox</h2>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-sm">Top agentic AI stories, synthesized daily. No noise — just signal. Free, unsubscribe any time.</p>
      </div>
      <form
        action="https://api.staticforms.xyz/submit"
        method="POST"
        class="flex flex-col xs:flex-row gap-3 w-full sm:w-auto sm:min-w-[300px]"
      >
  <input type="hidden" name="_site" value="aiagentic.news" />
        <input type="hidden" name="accessKey" value="sf_9e906eb6c00416b9d3354749" />
        <input type="hidden" name="subject" value="Enquiry from aiagentic.news" />
        <input type="hidden" name="redirectTo" value="https://aiagentic.news/?subscribed=1" />
        <input type="hidden" name="replyTo" value="@" />
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 px-4 py-3 rounded-xl bg-[var(--color-bg)]/80 border border-[var(--color-border-subtle)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] text-sm focus:outline-none focus:border-[var(--color-accent)]/50 transition-colors"
        />
        <button
          type="submit"
          class="px-5 py-3 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-semibold transition-colors whitespace-nowrap"
        >
          Subscribe →
        </button>
      </form>
    </div>
  </div>

  <!-- Divider -->
  <div class="my-12 h-px bg-gradient-to-r from-transparent via-[var(--color-border)] to-transparent"></div>

  <!-- Source Badges -->
  <SourceBadges />
</Base>
