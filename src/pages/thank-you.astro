---
import Base from '../layouts/Base.astro';
---
<Base title="Thanks" description="Message received." noindex={true}>
  <div class="max-w-2xl mx-auto text-center py-16">
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
      Thanks — message received
    </h1>
    <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed mb-8">
      We've got your details and will be in touch shortly.
    </p>
    <a href="/" class="inline-block px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-semibold hover:opacity-90 transition">Back to home</a>
  </div>
</Base>
