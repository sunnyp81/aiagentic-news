---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InfiniteGrid from '../components/InfiniteGrid.astro';
import AuroraGlow from '../components/AuroraGlow.astro';
import Particles from '../components/Particles.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
}

const { title, description = 'AI news curated and synthesized daily from across the web.', ogType = 'website', ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const WORKER = 'https://aiagentic-news-worker.sunnypat81.workers.dev';
const defaultOgImage = `${WORKER}/og?title=AI+Agentic+News&category=agents`;
const resolvedOgImage = ogImage || defaultOgImage;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | AI Agentic News</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={resolvedOgImage} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="AI Agentic News RSS" href="/rss.xml" />
  <meta name="theme-color" content="#060911" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-SWL1N3SZQ7"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-SWL1N3SZQ7');
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Background effects -->
  <InfiniteGrid />
  <AuroraGlow />
  <Particles />

  <!-- Content -->
  <div class="relative z-10 flex flex-col min-h-screen">
    <Header />
    <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-10">
      <slot />
    </main>
    <Footer />
  </div>
</body>
</html>
